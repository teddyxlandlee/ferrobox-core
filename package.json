{
  "name": "ferrobox-core",
  "version": "0.1.0",
  "description": "ChaCha20-Poly1305 segmented AEAD streaming encryption library for secure client-side storage",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json",
    "test": "npm run build && node ./test/roundtrip.test.js && node ./test/upload-download.test.js",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",

    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "js-base64": "^3.7.8"
  }
}
